# CockroachDB connection string
# Format: postgresql://user:password@host:26257/dbname?sslmode=verify-full
DATABASE_URL=postgresql://user:password@host:26257/dbname?sslmode=verify-full

# NextAuth
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-key-min-32-chars

# App URL (used for redirects)
NEXTAUTH_URL=http://localhost:3000

# Resend (email OTP)
# Get your API key at: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender email (must be verified domain in Resend)
EMAIL_FROM=FinTrack <noreply@yourdomain.com>
